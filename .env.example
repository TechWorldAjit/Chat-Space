# Environment variables template for Vercel deployment
# Copy these to your Vercel project environment variables

# Backend Server Environment Variables
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/database?retryWrites=true&w=majority&appName=Cluster
JWT_SECRET=your_jwt_secret_key_here
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Client Environment Variables
VITE_BACKEND_URL=https://your-backend-domain.vercel.app
VITE_API_BASE_URL=https://your-backend-domain.vercel.app
VITE_SOCKET_URL=https://your-backend-domain.vercel.app
